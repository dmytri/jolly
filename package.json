{
  "name": "@dk/jolly",
  "version": "0.12.3",
  "description": "Jolly sets up a Saleor Cloud storefront with Vercel and Stripe from your terminal or coding agent.",
  "type": "module",
  "bin": {
    "jolly": "bin/jolly"
  },
  "files": [
    "bin/",
    "dist/",
    "assets/messages/",
    "assets/skills/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20.12 --external:yaml --outfile=dist/index.js",
    "prepack": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20.12 --external:yaml --outfile=dist/index.js",
    "prepublishOnly": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20.12 --external:yaml --outfile=dist/index.js",
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "test": "node --test \"tests/**/*.test.ts\"",
    "test:bdd": "cucumber-js",
    "test:logic": "cucumber-js -p logic",
    "test:sandbox": "cucumber-js -p sandbox",
    "test:eval": "cucumber-js -p eval",
    "reclaim": "node features/support/reclaim-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "happy-dom": "^15.11.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@bomb.sh/args": "^0.3.1",
    "@bomb.sh/tab": "^0.0.17",
    "@clack/prompts": "^1.6.0",
    "yaml": "^2.9.0"
  }
}
