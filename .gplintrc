{
  "allow-all-caps": [
    "error",
    {
      "Global": false,
      "Description": false,
      "Feature": false,
      "Rule": false,
      "Background": false,
      "Scenario": false,
      "Step": false,
      "Example": false,
      "ExampleHeader": false,
      "ExampleBody": false
    }
  ],

  "allow-all-lowercase": [
    "error",
    {
      "Global": false,
      "Description": false,
      "Feature": false,
      "Rule": false,
      "Background": false,
      "Rule": true,
      "Scenario": true,
      "Step": true,
      "Example": true,
      "ExampleHeader": true,
      "ExampleBody": true
    }
  ],

  "allowed-tags": [
    "error",
    {
      "tags": [],
      "patterns": ["^@.+$"]
    }
  ],

  "file-name": "off",

  "indentation": "off",

  "keywords-in-logical-order": [
    "error",
    {
      "detectMissingKeywords": false
    }
  ],

  "max-keywords": [
    "error",
    {
      "given": 10,
      "when": 5,
      "then": 15,
      "onlyContiguous": false,
      "ignoreConjunctions": false
    }
  ],

  "max-scenarios-per-file": [
    "error",
    {
      "maxScenarios": 50,
      "countOutlineExamples": true
    }
  ],

  "max-tags-lines": [
    "error",
    {
      "feature": 1,
      "rule": 2,
      "scenario": 2,
      "example": 2
    }
  ],

  "name-length": [
    "error",
    {
      "Feature": 90,
      "Rule": 110,
      "Scenario": 110,
      "Step": 320
    }
  ],

  "new-line-at-eof": ["error", "yes"],

  "no-background-only-scenario": "error",
  "no-dupe-feature-names": "error",
  "no-dupe-scenario-names": ["error", "anywhere"],
  "no-duplicate-tags": "error",
  "no-empty-background": "error",
  "no-empty-file": "error",
  "no-examples-in-scenarios": "error",
  "no-files-without-scenarios": "error",
  "no-homogenous-tags": "off",
  "no-multiple-empty-lines": "error",

  "no-partially-commented-tag-lines": [
    "error",
    {
      "allowSeparated": false
    }
  ],

  "no-restricted-patterns": [
    "error",
    {
      "Global": [],
      "Feature": [],
      "Rule": [],
      "Background": [],
      "Scenario": [],
      "ScenarioOutline": [],
      "Examples": [],
      "ExampleHeader": [],
      "ExampleBody": [],
      "Step": [],
      "Given": [],
      "When": [],
      "Then": [],
      "DocString": [],
      "DataTable": []
    }
  ],

  "no-restricted-tags": [
    "error",
    {
      "tags": ["@ignore", "@disabled", "@todo", "@wip"],
      "patterns": ["^@skip.*", "^@todo.*", "^@wip.*"]
    }
  ],

  "no-scenario-outlines-without-examples": "error",
  "no-superfluous-tags": "error",
  "no-trailing-spaces": "error",
  "no-unnamed-features": "error",
  "no-unnamed-scenarios": "error",
  "no-unused-variables": "error",
  "one-space-between-tags": "error",

  "related-tags": [
    "error",
    {
      "tags": {}
    }
  ],

  "required-tags": [
    "error",
    {
      "ignoreUntagged": false,
      "global": [],
      "feature": [],
      "rule": [],
      "scenario": [],
      "example": [],
      "extendRule": true,
      "extendExample": true
    }
  ],

  "scenario-size": [
    "error",
    {
      "steps-length": {
        "Background": 12,
        "Scenario": 20
      }
    }
  ],

  "table-align": "off",

  "use-and": "error"
}
