#!/usr/bin/env node
"use strict";

// Jolly CLI launcher (feature 006, decision 2026-06-12): the published Jolly
// CLI is a Node.js program. This launcher runs the pre-built JavaScript bundle
// (`dist/index.js`, compiled from `src/`) under Node.js >= 20.12.0 — the floor
// its dependencies require (`@clack/prompts`; the `@bomb.sh/*` packages declare
// none), no stricter, because the published package runs compiled JavaScript and
// needs no newer runtime than its dependencies. It never invokes or requires Bun.
// (Bun was dropped project-wide on 2026-06-13: dev, test, CI, and the build all
// run on native Node + npm; dev/CI separately use Node >= 23 to run `src/` as raw
// TypeScript via native type stripping.)
//
// The published package ships compiled JS, not raw TypeScript: Node's native
// type stripping is disabled for files under `node_modules`, so an installed
// `npx @dk/jolly` must run plain JavaScript (correction 2026-06-13).
//
// Deliberately plain CommonJS-compatible JavaScript so that an old Node can
// parse it and reach the version guard below instead of dying with a raw
// syntax or module error.

/**
 * @planks("the published `jolly` launcher runs")
 * @planks("it should exit with an error naming the minimum Node version")
 */
var MIN_NODE_MAJOR = 20;
var MIN_NODE_LABEL = "20.12.0";

var nodeVersion = process.versions.node;
var nodeMajor = parseInt(nodeVersion.split(".")[0], 10);

if (!(nodeMajor >= MIN_NODE_MAJOR)) {
  console.error(
    "jolly requires Node.js >= " +
      MIN_NODE_LABEL +
      ", but this is Node.js " +
      nodeVersion +
      ". Please upgrade Node.js (https://nodejs.org) and try again.",
  );
  process.exit(1);
}

import("../dist/index.js").catch(function (error) {
  throw error;
});
